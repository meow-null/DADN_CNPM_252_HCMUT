generator client {
  provider = "prisma-client-js"
  output   = "../src/common/prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model bearings {
  id        Int       @id @default(autoincrement())
  code      String    @unique(map: "code") @db.VarChar(50)
  type      String?   @db.VarChar(50)
  inner_d   Decimal   @db.Decimal(10, 2)
  outer_D   Decimal   @db.Decimal(10, 2)
  width_B   Decimal   @db.Decimal(10, 2)
  C         Decimal?  @db.Decimal(12, 2)
  C0        Decimal?  @db.Decimal(12, 2)
  is_active Boolean?  @default(true)
  deletedBy Int?      @default(0)
  isDeleted Boolean?  @default(false)
  deletedAt DateTime? @db.Timestamp(0)
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @default(now()) @db.Timestamp(0)
  Y         Decimal?  @db.Decimal(10, 4)
  alpha_deg Decimal?  @db.Decimal(10, 2)
  e         Decimal?  @db.Decimal(10, 4)

  @@unique([inner_d, outer_D, width_B, type], map: "inner_d_unique")
}

model chains {
  id            Int       @id @default(autoincrement())
  pitch         Decimal   @unique(map: "pitch") @db.Decimal(10, 2)
  breaking_load Decimal?  @db.Decimal(12, 2)
  mass_per_m    Decimal?  @db.Decimal(10, 2)
  is_active     Boolean?  @default(true)
  deletedBy     Int?      @default(0)
  isDeleted     Boolean?  @default(false)
  deletedAt     DateTime? @db.Timestamp(0)
  createdAt     DateTime? @default(now()) @db.Timestamp(0)
  updatedAt     DateTime? @default(now()) @db.Timestamp(0)
  A_mm2         Decimal?  @db.Decimal(10, 2)
  P_allow       Decimal?  @db.Decimal(10, 2)
  n_ref         Int?
  s_allow       Decimal?  @db.Decimal(10, 2)
}

model motors {
  id            Int        @id @default(autoincrement())
  series        String?    @db.VarChar(10)
  code          String     @unique(map: "code") @db.VarChar(50)
  P_dm          Decimal    @db.Decimal(10, 2)
  n_dm          Int
  efficiency    Decimal?   @db.Decimal(5, 2)
  cos_phi       Decimal?   @db.Decimal(4, 2)
  t_start_ratio Decimal?   @db.Decimal(4, 2)
  t_max_ratio   Decimal?   @db.Decimal(4, 2)
  mass_kg       Decimal?   @db.Decimal(10, 2)
  price         Decimal?   @db.Decimal(12, 2)
  is_active     Boolean?   @default(true)
  deletedBy     Int?       @default(0)
  isDeleted     Boolean?   @default(false)
  deletedAt     DateTime?  @db.Timestamp(0)
  createdAt     DateTime?  @db.Timestamp(0)
  updatedAt     DateTime?  @db.Timestamp(0)
  projects      projects[]
}

model projects {
  id                      Int            @id @default(autoincrement())
  user_id                 Int
  name                    String         @db.VarChar(200)
  input_P                 Decimal        @db.Decimal(10, 2)
  input_n_ct              Decimal        @db.Decimal(10, 2)
  input_L                 Decimal        @db.Decimal(10, 2)
  efficiency              Decimal?       @db.Decimal(5, 4)
  Pct                     Decimal?       @db.Decimal(10, 2)
  total_ratio             Decimal?       @db.Decimal(10, 2)
  transmission            Json?
  shafts                  Json?
  safety_factor           Decimal?       @default(1.20) @db.Decimal(4, 2)
  selected_motor_id       Int?
  selected_motor_snapshot Json?
  design_result           Json?
  cover_url               String?        @db.VarChar(500)
  step                    projects_step? @default(created)
  deletedBy               Int?           @default(0)
  isDeleted               Boolean?       @default(false)
  deletedAt               DateTime?      @db.Timestamp(0)
  createdAt               DateTime?      @default(now()) @db.Timestamp(0)
  updatedAt               DateTime?      @default(now()) @db.Timestamp(0)
  selected_material_id    Int?
  users                   users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "projects_ibfk_1")
  motors                  motors?        @relation(fields: [selected_motor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "projects_ibfk_2")
  material_grade          material_grades? @relation(fields: [selected_material_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "projects_ibfk_3")

  @@index([selected_motor_id], map: "idx_projects_motor_id")
  @@index([selected_material_id], map: "idx_projects_material_id")
  @@index([user_id], map: "idx_projects_user_id")
}

model users {
  id                  Int         @id @default(autoincrement())
  name                String      @db.VarChar(100)
  email               String      @unique(map: "email") @db.VarChar(150)
  password            String      @db.VarChar(255)
  avatar_url          String?     @db.VarChar(500)
  role                users_role? @default(user)
  reset_token         String?     @db.VarChar(255)
  reset_token_expiry  DateTime?   @db.DateTime(0)
  is_verified         Boolean?    @default(false)
  verify_token        String?     @db.VarChar(255)
  verify_token_expiry DateTime?   @db.DateTime(0)
  deletedBy           Int?        @default(0)
  isDeleted           Boolean?    @default(false)
  deletedAt           DateTime?   @db.Timestamp(0)
  createdAt           DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt           DateTime?   @default(now()) @db.Timestamp(0)
  projects            projects[]
}

model material_grades {
  id         Int    @id @default(autoincrement())
  grade_name String @unique @db.VarChar(50)
  HB         Int
  sigma_b    Float
  sigma_ch   Float
  sigma_Hlim Float
  sigma_Flim Float
  projects   projects[]
}

model standard_modules {
  id    Int   @id @default(autoincrement())
  value Float @unique
}

model standard_center_distances {
  id    Int @id @default(autoincrement())
  value Int @unique
}

model standard_shaft_diameters {
  id    Int @id @default(autoincrement())
  value Int @unique
}

model key_dimensions {
  id    Int   @id @default(autoincrement())
  d_min Int
  d_max Int
  b     Int
  h     Int
  t1    Float
  t2    Float
}

model standard_key_lengths {
  id    Int @id @default(autoincrement())
  value Int @unique
}

model shaft_allowable_stress {
  id          Int   @id @default(autoincrement())
  d_range_min Float
  d_range_max Float
  sigma_b     Float
  sigma_allow Float
}

model kx_ksigma_coefficients {
  id          Int    @id @default(autoincrement())
  fit_type    String @db.VarChar(50)
  d_range_min Float
  d_range_max Float
  K_sigma     Float
  eps_sigma   Float
  beta_sigma  Float
}

enum users_role {
  user
  admin
}

enum projects_step {
  created
  inputs
  kinematics
  motor_selected
  design_partial
  design_done
}
