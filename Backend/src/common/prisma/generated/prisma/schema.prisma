generator client {
  provider = "prisma-client-js"
  output   = "../src/common/prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model bearings {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  type      String?  @db.VarChar(50)
  inner_d   Float
  outer_D   Float
  width_B   Float
  C         Float?
  C0        Float?
  e         Float?
  Y         Float?
  alpha_deg Float?
  is_active Boolean? @default(true)
}

model chains {
  id            Int      @id @default(autoincrement())
  pitch         Float    @unique
  P_allow       Float?
  breaking_load Float?
  mass_per_m    Float?
  A_mm2         Float?
  s_allow       Float?
  n_ref         Int?
  is_active     Boolean? @default(true)
}

model motors {
  id            Int        @id @default(autoincrement())
  series        String?    @db.VarChar(10)
  code          String     @unique(map: "code") @db.VarChar(50)
  P_dm          Decimal    @db.Decimal(10, 2)
  n_dm          Int
  efficiency    Decimal?   @db.Decimal(5, 2)
  cos_phi       Decimal?   @db.Decimal(4, 2)
  t_start_ratio Decimal?   @db.Decimal(4, 2)
  t_max_ratio   Decimal?   @db.Decimal(4, 2)
  mass_kg       Decimal?   @db.Decimal(10, 2)
  price         Decimal?   @db.Decimal(12, 2)
  is_active     Boolean?   @default(true)
  deletedBy     Int?       @default(0)
  isDeleted     Boolean?   @default(false)
  deletedAt     DateTime?  @db.Timestamp(0)
  createdAt     DateTime?  @default(now()) @db.Timestamp(0)
  updatedAt     DateTime?  @default(now()) @db.Timestamp(0)
  projects      projects[]
}

model projects {
  id                      Int            @id @default(autoincrement())
  user_id                 Int
  name                    String         @db.VarChar(200)
  input_P                 Decimal        @db.Decimal(10, 2)
  input_n_ct              Decimal        @db.Decimal(10, 2)
  input_L                 Decimal        @db.Decimal(10, 2)
  efficiency              Decimal?       @db.Decimal(5, 4)
  Pct                     Decimal?       @db.Decimal(10, 2)
  total_ratio             Decimal?       @db.Decimal(10, 2)
  transmission            Json?
  shafts                  Json?
  safety_factor           Decimal?       @default(1.20) @db.Decimal(4, 2)
  selected_motor_id       Int?
  selected_motor_snapshot Json?
  design_result           Json?
  step                    projects_step? @default(created)
  deletedBy               Int?           @default(0)
  isDeleted               Boolean?       @default(false)
  deletedAt               DateTime?      @db.Timestamp(0)
  createdAt               DateTime?      @default(now()) @db.Timestamp(0)
  updatedAt               DateTime?      @default(now()) @db.Timestamp(0)
  users                   users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "projects_ibfk_1")
  motors                  motors?        @relation(fields: [selected_motor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "projects_ibfk_2")

  @@index([selected_motor_id], map: "idx_projects_motor_id")
  @@index([user_id], map: "idx_projects_user_id")
}

model users {
  id                 Int         @id @default(autoincrement())
  name               String      @db.VarChar(100)
  email              String      @unique(map: "email") @db.VarChar(150)
  password           String      @db.VarChar(255)
  role               users_role? @default(user)
  reset_token        String?     @db.VarChar(255)
  reset_token_expiry DateTime?   @db.DateTime(0)
  deletedBy          Int?        @default(0)
  isDeleted          Boolean?    @default(false)
  deletedAt          DateTime?   @db.Timestamp(0)
  createdAt          DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt          DateTime?   @default(now()) @db.Timestamp(0)
  projects           projects[]
}

enum users_role {
  user
  admin
}

enum projects_step {
  created
  inputs
  kinematics
  motor_selected
  design_partial
  design_done
}

// Bảng tra cứu thông số cơ tính vật liệu (Dùng cho Module B, C, D)
model material_grades {
  id         Int    @id @default(autoincrement())
  grade_name String @unique @db.VarChar(50)
  HB         Int
  sigma_b    Float
  sigma_ch   Float
  sigma_Hlim Float
  sigma_Flim Float
}

// Dãy mô đun tiêu chuẩn
model standard_modules {
  id    Int   @id @default(autoincrement())
  value Float @unique
}

// Dãy khoảng cách trục tiêu chuẩn
model standard_center_distances {
  id    Int @id @default(autoincrement())
  value Int @unique
}

// Dãy đường kính trục tiêu chuẩn
model standard_shaft_diameters {
  id    Int @id @default(autoincrement())
  value Int @unique
}

// Kích thước then tiêu chuẩn theo đường kính
model key_dimensions {
  id    Int   @id @default(autoincrement())
  d_min Int
  d_max Int
  b     Int
  h     Int
  t1    Float // T_brc
  t2    Float // T_brt
}

model standard_key_lengths {
  id    Int @id @default(autoincrement())
  value Int @unique
}

// Bảng tra cứu ứng suất cho phép của trục theo đường kính và giới hạn bền
// Dùng cho Module D (Bước D13)
model shaft_allowable_stress {
  id          Int   @id @default(autoincrement())
  d_range_min Float // Giới hạn dưới của đường kính 
  d_range_max Float // Giới hạn trên của đường kính 
  sigma_b     Float // Giới hạn bền của vật liệu 
  sigma_allow Float // Ứng suất cho phép [sigma] 
}

// Bảng tra cứu các hệ số K_sigma, epsilon_sigma, beta
// Dùng cho Module D (Bước D21 - Kiểm nghiệm mỏi)
model kx_ksigma_coefficients {
  id          Int    @id @default(autoincrement())
  fit_type    String @db.VarChar(50)
  d_range_min Float
  d_range_max Float
  K_sigma     Float
  eps_sigma   Float
  beta_sigma  Float
}
